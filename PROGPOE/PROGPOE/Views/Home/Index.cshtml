@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<div class="text-center py-5">
    <i class="fas fa-file-contract fa-5x text-primary mb-4"></i>
    <h1 class="display-4">Welcome to TechMove, For All Your Logistics needs</h1>
    <p class="lead">TechMove</p>
    <hr class="my-4">
    <p>Manage contracts, service requests, and logistics operations efficiently.</p>
    
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-body text-center">
                    <i class="fas fa-file-contract fa-3x text-primary mb-3"></i>
                    <h5>Contract Management</h5>
                    <p>Create, sign, and manage contracts with ease.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-body text-center">
                    <i class="fas fa-tasks fa-3x text-success mb-3"></i>
                    <h5>Service Requests</h5>
                    <p>Submit and track service requests efficiently.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-body text-center">
                    <i class="fas fa-chart-line fa-3x text-info mb-3"></i>
                    <h5>Real-time Tracking</h5>
                    <p>Monitor contract status and request progress.</p>
                </div>
            </div>
        </div>
    </div>
</div>