@{
    ViewData["Title"] = "My Service Requests";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-tasks me-2"></i>My Service Requests</h2>
    <button class="btn btn-primary" onclick="openCreateModal()">
        <i class="fas fa-plus-circle me-2"></i>Raise New Request
    </button>
</div>

<div id="alertArea"></div>

<!-- Requests Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Request ID</th>
                        <th>Type</th>
                        <th>Contract</th>
                        <th>Description</th>
                        <th>Base Cost</th>
                        <th>USD Amount</th>
                        <th>ZAR Cost</th>
                        <th>Rate Used</th>
                        <th>Status</th>
                        <th>Admin Notes</th>
                    </tr>
                </thead>
                <tbody id="requestsBody">
                    <tr><td colspan="10" class="text-center py-4">
                        <div class="spinner-border text-primary"></div>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- CREATE REQUEST MODAL -->
<div class="modal fade" id="createModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Raise New Service Request</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="createAlert"></div>

                <!-- Step 1: Type & Contract -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Request Type <span class="text-danger">*</span></label>
                        <select id="reqType" class="form-select" onchange="toggleTypeFields()">
                            <option value="0">🚚 Freight Request</option>
                            <option value="1">🔧 Maintenance Request</option>
                        </select>
                        <div class="form-text">Freight → FreightRequestFactory &nbsp;|&nbsp; Maintenance → MaintenanceFactory</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Contract <span class="text-danger">*</span></label>
                        <select id="contractSelect" class="form-select" required>
                            <option value="">Loading your contracts...</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Origin / Location <span class="text-danger">*</span></label>
                    <input type="text" id="reqOrigin" class="form-control" placeholder="e.g. Cape Town Warehouse" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                    <textarea id="reqDesc" class="form-control" rows="2" placeholder="Describe the request..." required></textarea>
                </div>

                <!-- FREIGHT FIELDS -->
                <div id="freightFields">
                    <div class="card border-primary mb-3">
                        <div class="card-header bg-primary text-white py-2">
                            <i class="fas fa-truck me-2"></i>Freight Details
                            <small class="ms-2 opacity-75">Cost = WeightKg × R5.50 (via FreightRequestFactory)</small>
                        </div>
                        <div class="card-body row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Destination</label>
                                <input type="text" id="reqDest" class="form-control" placeholder="e.g. Johannesburg Hub">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Weight (kg)</label>
                                <input type="number" id="reqWeight" class="form-control" min="0.1" step="0.1" placeholder="e.g. 250">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MAINTENANCE FIELDS -->
                <div id="maintenanceFields" style="display:none">
                    <div class="card border-warning mb-3">
                        <div class="card-header bg-warning text-dark py-2">
                            <i class="fas fa-tools me-2"></i>Maintenance Details
                            <small class="ms-2 opacity-75">Cost = EstimatedHours × R120 (via MaintenanceFactory)</small>
                        </div>
                        <div class="card-body row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Equipment Type</label>
                                <input type="text" id="reqEquip" class="form-control" placeholder="e.g. Forklift, Generator">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Estimated Hours</label>
                                <input type="number" id="reqHours" class="form-control" min="1" placeholder="e.g. 4">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CURRENCY SECTION -->
                <div class="card border-success">
                    <div class="card-header bg-success text-white py-2">
                        <i class="fas fa-dollar-sign me-2"></i>Currency Conversion
                        <small class="ms-2 opacity-75">Live rate from open.er-api.com via HttpClient</small>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Amount in USD (optional)</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" id="usdAmount" class="form-control" min="0" step="0.01"
                                           placeholder="0.00" oninput="previewConversion()">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Live USD/ZAR Rate</label>
                                <div class="input-group">
                                    <input type="text" id="liveRate" class="form-control" readonly value="Loading...">
                                    <button class="btn btn-outline-secondary" type="button" onclick="fetchRate()" title="Refresh rate">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </div>
                                <div class="form-text" id="rateTimestamp"></div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">ZAR Equivalent</label>
                                <div class="input-group">
                                    <span class="input-group-text">R</span>
                                    <input type="text" id="zarPreview" class="form-control fw-bold" readonly value="—">
                                </div>
                                <div class="form-text text-success">Saved to database on submit</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="submitBtn" onclick="submitRequest()">
                    <i class="fas fa-paper-plane me-2"></i>Submit Request
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const token = localStorage.getItem('token');
    const role  = localStorage.getItem('role');
    if (!token || role !== 'Client') { window.location.href = '/Account/Login'; }

    function authFetch(url, opts = {}) {
        return fetch(url, {
            ...opts,
            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json', ...(opts.headers || {}) }
        });
    }

    // ── Load requests ────────────────────────────────────────────────────
    async function loadRequests() {
        const body = document.getElementById('requestsBody');
        body.innerHTML = '<tr><td colspan="10" class="text-center py-4"><div class="spinner-border text-primary"></div></td></tr>';
        try {
            const res = await authFetch('/api/client/service-requests');
            if (!res.ok) throw new Error();
            const reqs = await res.json();
            if (!reqs.length) {
                body.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-5"><i class="fas fa-inbox fa-2x d-block mb-2"></i>No requests yet. Press "Raise New Request" to create one.</td></tr>';
                return;
            }
            const statusColors = { Pending:'warning', Approved:'success', InProgress:'info', Completed:'primary', Denied:'danger' };
            body.innerHTML = reqs.map(r => '<tr>' +
                '<td><strong>' + r.requestId + '</strong></td>' +
                '<td><span class="badge bg-' + (r.type==='Freight'?'primary':'warning text-dark') + '">' + r.type + '</span></td>' +
                '<td>' + (r.contractNumber||'—') + '</td>' +
                '<td><small>' + r.description + '</small></td>' +
                '<td>R' + r.cost.toFixed(2) + '</td>' +
                '<td>' + (r.usdAmount ? '$' + r.usdAmount.toFixed(2) : '—') + '</td>' +
                '<td>' + (r.localCostZar ? 'R' + r.localCostZar.toFixed(2) : '—') + '</td>' +
                '<td>' + (r.exchangeRateUsed ? r.exchangeRateUsed.toFixed(4) : '—') + '</td>' +
                '<td><span class="badge bg-' + (statusColors[r.status]||'secondary') + '">' + r.status + '</span></td>' +
                '<td><small class="text-muted">' + (r.adminNotes||'—') + '</small></td>' +
                '</tr>').join('');
        } catch {
            body.innerHTML = '<tr><td colspan="10" class="text-center text-danger py-4">Failed to load requests.</td></tr>';
        }
    }

    // ── Load contracts into dropdown ─────────────────────────────────────
    async function loadContracts() {
        const sel = document.getElementById('contractSelect');
        sel.innerHTML = '<option value="">Loading...</option>';
        try {
            const res = await authFetch('/api/client/contracts');
            const contracts = await res.json();
            const active = contracts.filter(c => c.status === 'Active');
            if (!active.length) {
                sel.innerHTML = '<option value="">No active contracts — ask admin to activate one</option>';
            } else {
                sel.innerHTML = '<option value="">— Select contract —</option>' +
                    active.map(c => '<option value="' + c.contractId + '">' + c.contractNumber + ' (' + c.serviceLevel + ')</option>').join('');
            }
        } catch {
            sel.innerHTML = '<option value="">Failed to load contracts</option>';
        }
    }

    // ── Live rate fetch ──────────────────────────────────────────────────
    let currentRate = null;
    async function fetchRate() {
        const rateEl = document.getElementById('liveRate');
        const tsEl   = document.getElementById('rateTimestamp');
        rateEl.value = 'Fetching...';
        try {
            const res = await authFetch('/api/client/currency/rate');
            const data = await res.json();
            currentRate = data.rate;
            rateEl.value = currentRate.toFixed(4);
            tsEl.textContent = 'Updated: ' + new Date(data.timestamp).toLocaleTimeString();
            previewConversion();
        } catch {
            rateEl.value = 'Unavailable';
            tsEl.textContent = 'Using fallback rate';
        }
    }

    function previewConversion() {
        const usd = parseFloat(document.getElementById('usdAmount').value) || 0;
        const preview = document.getElementById('zarPreview');
        if (usd > 0 && currentRate) {
            preview.value = (usd * currentRate).toFixed(2);
        } else {
            preview.value = '—';
        }
    }

    // ── Toggle freight / maintenance fields ──────────────────────────────
    function toggleTypeFields() {
        const t = parseInt(document.getElementById('reqType').value);
        document.getElementById('freightFields').style.display     = t === 0 ? '' : 'none';
        document.getElementById('maintenanceFields').style.display = t === 1 ? '' : 'none';
    }

    // ── Open modal ───────────────────────────────────────────────────────
    function openCreateModal() {
        document.getElementById('createAlert').innerHTML = '';
        document.getElementById('reqType').value = '0';
        document.getElementById('reqOrigin').value = '';
        document.getElementById('reqDesc').value = '';
        document.getElementById('reqDest').value = '';
        document.getElementById('reqWeight').value = '';
        document.getElementById('reqEquip').value = '';
        document.getElementById('reqHours').value = '';
        document.getElementById('usdAmount').value = '';
        document.getElementById('zarPreview').value = '—';
        toggleTypeFields();
        loadContracts();
        fetchRate();
        const btn = document.getElementById('submitBtn');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Submit Request';
        new bootstrap.Modal(document.getElementById('createModal')).show();
    }

    // ── Submit ───────────────────────────────────────────────────────────
    async function submitRequest() {
        const alertEl = document.getElementById('createAlert');
        alertEl.innerHTML = '';

        const type       = parseInt(document.getElementById('reqType').value);
        const contractId = parseInt(document.getElementById('contractSelect').value);
        const origin     = document.getElementById('reqOrigin').value.trim();
        const desc       = document.getElementById('reqDesc').value.trim();
        const usdRaw     = parseFloat(document.getElementById('usdAmount').value) || null;

        if (!contractId) { alertEl.innerHTML = '<div class="alert alert-danger">Please select a contract.</div>'; return; }
        if (!origin)     { alertEl.innerHTML = '<div class="alert alert-danger">Origin is required.</div>'; return; }
        if (!desc)       { alertEl.innerHTML = '<div class="alert alert-danger">Description is required.</div>'; return; }

        const body = { ContractId: contractId, Type: type, Origin: origin, Desc: desc, UsdAmount: usdRaw };

        if (type === 0) {
            body.Dest   = document.getElementById('reqDest').value.trim();
            body.Weight = parseFloat(document.getElementById('reqWeight').value) || null;
            if (!body.Weight) { alertEl.innerHTML = '<div class="alert alert-danger">Freight requires a weight.</div>'; return; }
        } else {
            body.Equip = document.getElementById('reqEquip').value.trim();
            body.Hours = parseInt(document.getElementById('reqHours').value) || null;
            if (!body.Hours) { alertEl.innerHTML = '<div class="alert alert-danger">Maintenance requires estimated hours.</div>'; return; }
        }

        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';

        try {
            const res = await authFetch('/api/client/service-requests', { method: 'POST', body: JSON.stringify(body) });
            const data = await res.json();
            if (res.ok) {
                bootstrap.Modal.getInstance(document.getElementById('createModal')).hide();
                let msg = '<i class="fas fa-check-circle me-2"></i>Request <strong>' + data.requestId + '</strong> submitted!';
                if (data.localCostZar) msg += ' &nbsp;|&nbsp; ZAR equivalent: <strong>R' + parseFloat(data.localCostZar).toFixed(2) + '</strong> (rate: ' + parseFloat(data.exchangeRateUsed).toFixed(4) + ')';
                showAlert('success', msg);
                loadRequests();
            } else {
                alertEl.innerHTML = '<div class="alert alert-danger">' + (data.message || 'Submission failed.') + '</div>';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Submit Request';
            }
        } catch {
            alertEl.innerHTML = '<div class="alert alert-danger">Network error. Please try again.</div>';
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Submit Request';
        }
    }

    function showAlert(type, html) {
        const el = document.getElementById('alertArea');
        el.innerHTML = '<div class="alert alert-' + type + ' alert-dismissible fade show">' + html +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
        el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    loadRequests();
</script>
}
