@{
    ViewData["Title"] = "My Service Requests";
    Layout = "_Layout";
}

<h2 class="mb-4"><i class="fas fa-tasks me-2"></i>My Service Requests</h2>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Request ID</th>
                        <th>Type</th>
                        <th>Contract</th>
                        <th>Origin</th>
                        <th>Cost</th>
                        <th>Status</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody id="requestsBody">
                    <tr><td colspan="7" class="text-center py-4">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadRequests() {
            try {
                const response = await apiFetch('/api/Client/service-requests');
                const requests = await response.json();
                
                const statusColors = { 'Pending': 'warning', 'Approved': 'success', 'InProgress': 'info', 'Completed': 'primary', 'Denied': 'danger' };
                
                document.getElementById('requestsBody').innerHTML = requests.map(r => `
                    <tr>
                        <td><strong>${r.requestId}</strong></td>
                        <td>${r.type}</td>
                        <td>${r.contractNumber || 'N/A'}</td>
                        <td>${r.origin}</td>
                        <td>$${r.cost.toFixed(2)}</td>
                        <td><span class="badge bg-${statusColors[r.status] || 'secondary'}">${r.status}</span></td>
                        <td>${r.adminNotes || '-'}</td>
                    </tr>
                `).join('') || '<tr><td colspan="7" class="text-center py-4">No requests found</td></tr>';
            } catch (err) {
                document.getElementById('requestsBody').innerHTML = '<tr><td colspan="7" class="text-center text-danger py-4">Failed to load requests</td></tr>';
            }
        }
        
        loadRequests();
    </script>
}