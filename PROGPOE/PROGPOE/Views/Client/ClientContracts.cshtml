@{
    ViewData["Title"] = "My Contracts";
    Layout = "_Layout";
}

<h2 class="mb-4"><i class="fas fa-file-contract me-2"></i>My Contracts</h2>

<div class="row" id="contractsRow">
    <div class="col-12 text-center py-4">
        <div class="spinner-border text-primary"></div>
        <p class="mt-2">Loading contracts...</p>
    </div>
</div>

<!-- Create Request Modal -->
<div class="modal fade" id="requestModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Service Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="requestForm">
                <input type="hidden" id="rContractId">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select id="rType" class="form-select" onchange="toggleFields()">
                            <option value="0">Freight</option>
                            <option value="1">Maintenance</option>
                        </select>
                    </div>
                    <div class="mb-3"><label class="form-label">Origin</label><input type="text" id="rOrigin" class="form-control" required></div>
                    <div class="mb-3"><label class="form-label">Description</label><textarea id="rDescription" class="form-control" required></textarea></div>
                    <div id="freightFields">
                        <div class="mb-3"><label class="form-label">Destination</label><input type="text" id="rDestination" class="form-control"></div>
                        <div class="mb-3"><label class="form-label">Weight (kg)</label><input type="number" id="rWeightKg" class="form-control" step="0.1"></div>
                    </div>
                    <div id="maintenanceFields" style="display:none;">
                        <div class="mb-3"><label class="form-label">Equipment Type</label><input type="text" id="rEquipmentType" class="form-control"></div>
                        <div class="mb-3"><label class="form-label">Estimated Hours</label><input type="number" id="rEstimatedHours" class="form-control"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Submit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadContracts() {
            try {
                const response = await apiFetch('/api/Client/contracts');
                const contracts = await response.json();
                
                const statusColors = { 'Draft': 'secondary', 'Active': 'success', 'Expired': 'danger', 'OnHold': 'warning' };
                
                document.getElementById('contractsRow').innerHTML = contracts.map(c => `
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between">
                                <strong>${c.contractNumber}</strong>
                                <span class="badge bg-${statusColors[c.status] || 'secondary'}">${c.status}</span>
                            </div>
                            <div class="card-body">
                                <p><strong>Start:</strong> ${new Date(c.startDate).toLocaleDateString()}</p>
                                <p><strong>End:</strong> ${new Date(c.endDate).toLocaleDateString()}</p>
                                <p><strong>Level:</strong> ${c.serviceLevel}</p>
                                <button class="btn btn-primary btn-sm" onclick="showRequestModal(${c.contractId})">Create Request</button>
                                ${c.status === 'Draft' ? `<button class="btn btn-success btn-sm" onclick="signContract(${c.contractId})">Sign Contract</button>` : ''}
                            </div>
                        </div>
                    </div>
                `).join('') || '<div class="col-12"><div class="alert alert-info">No contracts found</div></div>';
            } catch (err) {
                document.getElementById('contractsRow').innerHTML = '<div class="alert alert-danger">Failed to load contracts</div>';
            }
        }
        
        async function signContract(id) {
            await apiFetch(`/api/Client/contracts/${id}/sign`, { method: 'POST' });
            loadContracts();
        }
        
        function showRequestModal(contractId) {
            document.getElementById('rContractId').value = contractId;
            new bootstrap.Modal(document.getElementById('requestModal')).show();
        }
        
        function toggleFields() {
            const type = document.getElementById('rType').value;
            document.getElementById('freightFields').style.display = type === '0' ? 'block' : 'none';
            document.getElementById('maintenanceFields').style.display = type === '1' ? 'block' : 'none';
        }
        
        document.getElementById('requestForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const type = parseInt(document.getElementById('rType').value);
            const body = {
                contractId: parseInt(document.getElementById('rContractId').value),
                type: type,
                origin: document.getElementById('rOrigin').value,
                description: document.getElementById('rDescription').value
            };
            
            if (type === 0) {
                body.destination = document.getElementById('rDestination').value;
                body.weightKg = parseFloat(document.getElementById('rWeightKg').value);
            } else {
                body.equipmentType = document.getElementById('rEquipmentType').value;
                body.estimatedHours = parseInt(document.getElementById('rEstimatedHours').value);
            }
            
            try {
                const response = await apiFetch('/api/Client/service-requests', {
                    method: 'POST',
                    body: JSON.stringify(body)
                });
                if (response.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('requestModal')).hide();
                    alert('Request created!');
                }
            } catch (err) {
                alert('Failed to create request');
            }
        });
        
        loadContracts();
    </script>
}