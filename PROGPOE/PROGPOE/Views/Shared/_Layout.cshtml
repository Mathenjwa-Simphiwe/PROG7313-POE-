<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GLMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
            .navbar-brand i { color: #ffd700; }
            .card { transition: transform 0.2s; }
            .card:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
            .status-badge { font-size: 0.85rem; }
            .footer { margin-top: 3rem; padding: 1.5rem 0; background: #f8f9fa; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-file-contract"></i> GLMS
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto" id="navMenu">
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item" id="userInfo" style="display:none;">
                        <span class="nav-link text-light">
                            <i class="fas fa-user"></i> <span id="userName"></span>
                        </span>
                    </li>
                    <li class="nav-item" id="loginLink">
                        <a class="nav-link text-light" href="/Account/Login">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </li>
                    <li class="nav-item" id="logoutLink" style="display:none;">
                        <a class="nav-link text-light" href="#" onclick="logout()">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="footer text-muted text-center">
        <div class="container">
            &copy; 2025 - General Logistics Management System
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const token = localStorage.getItem('token');
        const role = localStorage.getItem('role');
        const fullName = localStorage.getItem('fullName');
        
        const navMenu = document.getElementById('navMenu');
        const loginLink = document.getElementById('loginLink');
        const logoutLink = document.getElementById('logoutLink');
        const userInfo = document.getElementById('userInfo');
        
        if (token && role) {
        loginLink.style.display = 'none';
        logoutLink.style.display = 'block';
        userInfo.style.display = 'block';
        document.getElementById('userName').textContent = fullName || 'User';
            
        if (role === 'Admin') {
        navMenu.innerHTML = `
        <li class="nav-item"><a class="nav-link text-light" href="/Admin/Dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-light" href="/Admin/Contracts"><i class="fas fa-file-contract"></i> Contracts</a></li>
        <li class="nav-item"><a class="nav-link text-light" href="/Admin/ServiceRequests"><i class="fas fa-tasks"></i> Service Requests</a></li>
        `;
        } else if (role === 'Client') {
        navMenu.innerHTML = `
        <li class="nav-item"><a class="nav-link text-light" href="/Client/Dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-light" href="/Client/MyContracts"><i class="fas fa-file-contract"></i> My Contracts</a></li>
        <li class="nav-item"><a class="nav-link text-light" href="/Client/MyRequests"><i class="fas fa-tasks"></i> My Requests</a></li>
        `;
        }
        }
        
        function logout() {
        localStorage.clear();
        window.location.href = '/Account/Login';
        }
        
        // Add token to all fetch requests
        async function apiFetch(url, options = {}) {
        const headers = {
        'Content-Type': 'application/json',
        ...options.headers
        };
        if (token) headers['Authorization'] = `Bearer ${token}`;
            
        const response = await fetch(url, { ...options, headers });
        if (response.status === 401) { logout(); return null; }
        return response;
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>