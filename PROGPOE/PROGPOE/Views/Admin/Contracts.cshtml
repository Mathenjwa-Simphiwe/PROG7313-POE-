@{
    ViewData["Title"] = "Manage Contracts";
    Layout = "_Layout";
}

<h2 class="mb-4"><i class="fas fa-file-contract me-2"></i>Contract Management</h2>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filter Contracts</h5></div>
    <div class="card-body">
        <form id="filterForm" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Start Date</label>
                <input type="date" id="startDate" class="form-control">
            </div>
            <div class="col-md-4">
                <label class="form-label">End Date</label>
                <input type="date" id="endDate" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select id="status" class="form-select">
                    <option value="">All</option>
                    <option value="0">Draft</option>
                    <option value="1">Active</option>
                    <option value="2">Expired</option>
                    <option value="3">On Hold</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i></button>
            </div>
        </form>
    </div>
</div>

<!-- Create Contract Button -->
<button class="btn btn-success mb-3" onclick="showCreateModal()">
    <i class="fas fa-plus-circle me-2"></i>Create New Contract
</button>

<!-- Contracts Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Contract #</th>
                        <th>Client</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>Level</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="contractsBody">
                    <tr><td colspan="7" class="text-center py-4">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Contract Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Contract</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createForm" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Client ID</label>
                        <input type="text" id="clientId" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" id="cStartDate" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">End Date</label>
                        <input type="date" id="cEndDate" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Service Level</label>
                        <select id="cServiceLevel" class="form-select">
                            <option value="0">Standard</option>
                            <option value="1">Premium</option>
                            <option value="2">Enterprise</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Agreement (PDF)</label>
                        <input type="file" id="cAgreement" class="form-control" accept=".pdf">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadContracts() {
            try {
                const token = localStorage.getItem('token');
                const baseUrl = window.location.origin;
                
                const response = await fetch(baseUrl + '/api/client/contracts', {
                    headers: {
                        'Authorization': 'Bearer ' + token,
                        'Content-Type': 'application/json'
                    }
                });
                
                if (response.ok) {
                    const contracts = await response.json();
                    
                    if (contracts.length === 0) {
                        document.getElementById('contractsRow').innerHTML =
                            '<div class="col-12"><div class="alert alert-info">No contracts found</div></div>';
                        return;
                    }
                    
                    document.getElementById('contractsRow').innerHTML = contracts.map(c => `
                        <div class="col-md-6 mb-3">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between">
                                    <strong>${c.contractNumber}</strong>
                                    <span class="badge bg-${c.status === 'Active' ? 'success' : 'secondary'}">${c.status}</span>
                                </div>
                                <div class="card-body">
                                    <p><strong>Start:</strong> ${new Date(c.startDate).toLocaleDateString()}</p>
                                    <p><strong>End:</strong> ${new Date(c.endDate).toLocaleDateString()}</p>
                                    <p><strong>Level:</strong> ${c.serviceLevel}</p>
                                </div>
                            </div>
                        </div>
                    `).join('');
                }
            } catch (err) {
                console.error('Error:', err);
            }
        }
        
        loadContracts();
    </script>
}