@{
    ViewData["Title"] = "Manage Contracts";
    Layout = "_Layout";
}

<h2 class="mb-4"><i class="fas fa-file-contract me-2"></i>Contract Management</h2>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filter Contracts</h5></div>
    <div class="card-body">
        <form id="filterForm" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Start Date</label>
                <input type="date" id="startDate" class="form-control">
            </div>
            <div class="col-md-4">
                <label class="form-label">End Date</label>
                <input type="date" id="endDate" class="form-control">
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select id="status" class="form-select">
                    <option value="">All</option>
                    <option value="0">Draft</option>
                    <option value="1">Active</option>
                    <option value="2">Expired</option>
                    <option value="3">On Hold</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i></button>
            </div>
        </form>
    </div>
</div>

<!-- Create Contract Button -->
<button class="btn btn-success mb-3" onclick="showCreateModal()">
    <i class="fas fa-plus-circle me-2"></i>Create New Contract
</button>

<!-- Contracts Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Contract #</th>
                        <th>Client</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>Level</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="contractsBody">
                    <tr><td colspan="7" class="text-center py-4">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Contract Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Contract</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createForm" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Client ID</label>
                        <input type="text" id="clientId" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Start Date</label>
                        <input type="date" id="cStartDate" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">End Date</label>
                        <input type="date" id="cEndDate" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Service Level</label>
                        <select id="cServiceLevel" class="form-select">
                            <option value="0">Standard</option>
                            <option value="1">Premium</option>
                            <option value="2">Enterprise</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Agreement (PDF)</label>
                        <input type="file" id="cAgreement" class="form-control" accept=".pdf">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadContracts(filters = {}) {
            const params = new URLSearchParams();
            if (filters.startDate) params.append('startDate', filters.startDate);
            if (filters.endDate) params.append('endDate', filters.endDate);
            if (filters.status) params.append('status', filters.status);
            
            try {
                const response = await apiFetch(`/api/Admin/contracts?${params}`);
                const contracts = await response.json();
                
                const statusColors = { 'Draft': 'secondary', 'Active': 'success', 'Expired': 'danger', 'OnHold': 'warning', 'Terminated': 'dark' };
                
                document.getElementById('contractsBody').innerHTML = contracts.map(c => `
                    <tr>
                        <td><strong>${c.contractNumber}</strong></td>
                        <td>${c.clientName || 'N/A'}</td>
                        <td>${new Date(c.startDate).toLocaleDateString()}</td>
                        <td>${new Date(c.endDate).toLocaleDateString()}</td>
                        <td><span class="badge bg-${statusColors[c.status] || 'secondary'}">${c.status}</span></td>
                        <td>${c.serviceLevel}</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                ${c.hasAgreement ? `<a href="/api/Admin/contracts/${c.contractId}/download" class="btn btn-outline-info"><i class="fas fa-download"></i></a>` : ''}
                                <button class="btn btn-outline-warning" onclick="changeStatus(${c.contractId})"><i class="fas fa-edit"></i></button>
                            </div>
                        </td>
                    </tr>
                `).join('') || '<tr><td colspan="7" class="text-center py-4">No contracts found</td></tr>';
            } catch (err) {
                document.getElementById('contractsBody').innerHTML = '<tr><td colspan="7" class="text-center text-danger py-4">Failed to load contracts</td></tr>';
            }
        }
        
        document.getElementById('filterForm').addEventListener('submit', (e) => {
            e.preventDefault();
            loadContracts({
                startDate: document.getElementById('startDate').value,
                endDate: document.getElementById('endDate').value,
                status: document.getElementById('status').value
            });
        });
        
        function showCreateModal() {
            new bootstrap.Modal(document.getElementById('createModal')).show();
        }
        
        document.getElementById('createForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData();
            formData.append('ClientId', document.getElementById('clientId').value);
            formData.append('StartDate', document.getElementById('cStartDate').value);
            formData.append('EndDate', document.getElementById('cEndDate').value);
            formData.append('ServiceLevel', document.getElementById('cServiceLevel').value);
            
            const fileInput = document.getElementById('cAgreement');
            if (fileInput.files[0]) formData.append('Agreement', fileInput.files[0]);
            
            try {
                const response = await fetch('/api/Admin/contracts', {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` },
                    body: formData
                });
                if (response.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('createModal')).hide();
                    loadContracts();
                }
            } catch (err) {
                alert('Failed to create contract');
            }
        });
        
        async function changeStatus(id) {
            const status = prompt('Enter new status (Draft=0, Active=1, Expired=2, OnHold=3):');
            if (status) {
                await apiFetch(`/api/Admin/contracts/${id}/status`, {
                    method: 'PUT',
                    body: JSON.stringify({ status: parseInt(status) })
                });
                loadContracts();
            }
        }
        
        loadContracts();
    </script>
}