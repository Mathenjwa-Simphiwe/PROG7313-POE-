@{
    ViewData["Title"] = "Service Requests";
    Layout = "_Layout";
}

<h2 class="mb-4"><i class="fas fa-tasks me-2"></i>Service Requests</h2>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Request ID</th>
                        <th>Type</th>
                        <th>Contract</th>
                        <th>Client</th>
                        <th>Cost</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="requestsBody">
                    <tr><td colspan="7" class="text-center py-4">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadRequests() {
            try {
                const response = await apiFetch('/api/Admin/service-requests');
                const requests = await response.json();
                
                const statusColors = { 'Pending': 'warning', 'Approved': 'success', 'InProgress': 'info', 'Completed': 'primary', 'Denied': 'danger' };
                
                document.getElementById('requestsBody').innerHTML = requests.map(r => `
                    <tr>
                        <td><strong>${r.requestId}</strong></td>
                        <td>${r.type}</td>
                        <td>${r.contractNumber || 'N/A'}</td>
                        <td>${r.clientName || 'N/A'}</td>
                        <td>$${r.cost.toFixed(2)}</td>
                        <td><span class="badge bg-${statusColors[r.status] || 'secondary'}">${r.status}</span></td>
                        <td>
                            ${r.status === 'Pending' ? `
                                <button class="btn btn-success btn-sm" onclick="approveRequest(${r.serviceRequestId})"><i class="fas fa-check"></i></button>
                                <button class="btn btn-danger btn-sm" onclick="denyRequest(${r.serviceRequestId})"><i class="fas fa-times"></i></button>
                            ` : '<small class="text-muted">Processed</small>'}
                        </td>
                    </tr>
                `).join('') || '<tr><td colspan="7" class="text-center py-4">No requests found</td></tr>';
            } catch (err) {
                document.getElementById('requestsBody').innerHTML = '<tr><td colspan="7" class="text-center text-danger py-4">Failed to load requests</td></tr>';
            }
        }
        
        async function approveRequest(id) {
            const notes = prompt('Add notes (optional):');
            await apiFetch(`/api/Admin/service-requests/${id}/approve`, {
                method: 'PUT',
                body: JSON.stringify({ notes })
            });
            loadRequests();
        }
        
        async function denyRequest(id) {
            const notes = prompt('Reason for denial:');
            if (notes) {
                await apiFetch(`/api/Admin/service-requests/${id}/deny`, {
                    method: 'PUT',
                    body: JSON.stringify({ notes })
                });
                loadRequests();
            }
        }
        
        loadRequests();
    </script>
}